# Generic remote-MFE image: build one Angular project, serve its bundle via nginx.
# Usage: docker build -f Dockerfile.mfe --build-arg PROJECT=master-data .
FROM node:22 AS build
WORKDIR /app
COPY package*.json ./
RUN npm ci
COPY . .
ARG PROJECT
RUN npx ng build ${PROJECT} --configuration production

FROM nginx:alpine AS runtime
ARG PROJECT
COPY --from=build /app/dist/${PROJECT}/browser /usr/share/nginx/html
COPY docker/nginx-mfe.conf /etc/nginx/conf.d/default.conf
EXPOSE 8080
