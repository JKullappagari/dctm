    protected void ibCreateAsset_Click(object sender, Infragistics.WebUI.WebDataInput.ButtonEventArgs e)
    {
        //v3.8
        // check whether site restriction is enabled or not
        // if enabled check whether user has write permission on the selected 
        // if user has write permission than allow the create asset 
        //else show message and cancel create asset.
        if (bool.Parse(Session["SiteRestrictEnabled"].ToString()) == false)
        {
            //check Mount type selected, if mount type = 'rack mount' than check whether start position and no of rus specified
            // if not return and ask user to specify start position and no of rus.
            //if mount type is 'standalone' than these values are optional
            int locationID = 0;
            if (!string.IsNullOrEmpty(hdnLocID.Value))
            {
                locationID = int.Parse(hdnLocID.Value.ToString());
                LocationBAL locBAL = new LocationBAL();
                locBAL.LocationID = locationID;
                DataSet dsLoc = locBAL.retrieve();
                if (dsLoc.Tables.Count > 0 && dsLoc.Tables[3].Rows.Count > 0)
                {
                    string locType = dsLoc.Tables[3].Rows[0][DBFields.DBFIELD_LOCATIONTYPE].ToString();
                    if (locType.ToLower().CompareTo("rack") == 0)
                    {
                        if (ddlMount.SelectedItem.Text.ToLower().CompareTo("rackmount") == 0)
                        {
                            //rack

                            //release current u-position
                            int startpos, noofrus;
                            if (!String.IsNullOrEmpty(Session["StartPos"].ToString()))
                                startpos = int.Parse(Session["StartPos"].ToString());
                            else
                            {
                                startpos = 0;
                            }

                            if (!String.IsNullOrEmpty(Session["NoOfRUs"].ToString()))
                                noofrus = int.Parse(Session["NoOfRUs"].ToString());
                            else
                            {
                                noofrus = 0;
                            }

                            locBAL.UpdateUpositionDetails(locationID, startpos, noofrus, false);

                            locBAL.LocationID = locationID;
                            DataSet ds = locBAL.retrieveUPositions();
                            byte[] bytes = (byte[])(ds.Tables[0].Rows[0][DBFields.DBFIELD_UPOSITIONS]);

                            if (ddlPosition.SelectedIndex <= 0 || ddlNoOfRU.SelectedIndex <= 0)
                            {
                                lblErrorMsg.Visible = true;
                                lblErrorMsg.Text = "select Start Position and No of RUs for rack mount asset";
                                return;
                            }
                            else
                            {
                                BitArray positions = new BitArray(48);
                                int idx = 0;
                                for (int i = 0; i < bytes.Length; i++)
                                {
                                    BitArray x = new BitArray(new byte[] { bytes[i] });
                                    Reverse(x);
                                    for (int j = 0; j < x.Length; j++)
                                    {
                                        positions.Set(idx++, x[j]);
                                    }
                                }


                                if (!CheckUPosition(int.Parse(ddlPosition.SelectedItem.Text), int.Parse(ddlNoOfRU.SelectedItem.Text), positions))
                                {
                                    lblErrorMsg.Visible = true;
                                    lblErrorMsg.Text = "U-position is in use";
                                    return;
                                }
                            }
                        }
                        else
                        {
                            //standalone optional
                        }
                    }
                    else
                    {
                        //Room or Row 
                    }
                }
                else
                {
                    lblErrorMsg.Visible = true;
                    lblErrorMsg.Text = "Invalid location. Select location";
                    return;
                }
            }
            else
            {
                lblErrorMsg.Visible = true;
                lblErrorMsg.Text = "Invalid location. Select location";
                return;
            }
            Create();
            //--//
        }
        else
        {
            //Site restriction enabled
            SiteRestrictionsBAL objSRBAL = new SiteRestrictionsBAL();
            objSRBAL.UserID = int.Parse(Session["UserID"].ToString());
            DataSet dsSR = objSRBAL.RetrieveByUserID();
            DataTable dtSR = dsSR.Tables[0];
            //check the dataset to see whether the site has read/write permission than only allow create.
            //0-no Access, 1- Read,2- Read/Write
            DataRow[] rows = dtSR.Select("SiteID = " + ddlSite.SelectedItem.Value);
            int restrictionType = int.Parse(rows[0]["ResTypeID"].ToString());
            if (restrictionType == 2)
            {
                Create();
            }
            else
            {
                lblErrorMsg.Visible = true;
                lblErrorMsg.Text = "No write permissions on the selected site. Asset update is cancelled";
            }
        }
        //HIde Location Selection image button (v4.5)
        //Location change will be disabled in Edit Asset and Modify All pages
        Page.ClientScript.RegisterStartupScript(this.GetType(), "script", "disableLocButton();", true);
    }

