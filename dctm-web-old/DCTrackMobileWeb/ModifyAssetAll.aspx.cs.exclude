    protected void cusCustom_ServerValidate(object sender, ServerValidateEventArgs e)
    {
        int val = Int32.Parse(e.Value);
        if (val > 0)
            e.IsValid = true;
        else
            e.IsValid = false;
    }

    protected void cusCustom_ServerValidate_ddlMfg(object sender, ServerValidateEventArgs e)
    {
        int val = Int32.Parse(e.Value);
        if (val > 0)
            e.IsValid = true;
        else
            e.IsValid = false;
    }



