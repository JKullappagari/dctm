        dc = new DataColumn("Orientation", typeof(string));
        DtAsset.Columns.Add(dc);
        dc = new DataColumn("StartPos", typeof(string));
        DtAsset.Columns.Add(dc);
        dc = new DataColumn("NoOfRUs", typeof(string));
        DtAsset.Columns.Add(dc);//*



        DataSet dtModify = objAssetModifyAll.GetAssetDetailsModifyAll(AssetId);

        for (int i = 0; i <= dtModify.Tables[0].Rows.Count - 1; i++)
        {
            DtAsset.Rows.Add(dtModify.Tables[0].Rows[i]["BusinessUnit"].ToString(), dtModify.Tables[0].Rows[i]["Site"].ToString(), dtModify.Tables[0].Rows[i]["LastLocation"].ToString(),
                dtModify.Tables[0].Rows[i]["RefNumber"].ToString(), dtModify.Tables[0].Rows[i]["MfgName"].ToString(),
                dtModify.Tables[0].Rows[i]["ModelName"].ToString(), dtModify.Tables[0].Rows[i]["TechName"].ToString(),
                dtModify.Tables[0].Rows[i]["RackorStand"].ToString(), dtModify.Tables[0].Rows[i]["AssetGroup"].ToString(),
                dtModify.Tables[0].Rows[i]["OS"].ToString(), dtModify.Tables[0].Rows[i]["CPU"].ToString(),
                dtModify.Tables[0].Rows[i]["CPUCount"].ToString(), dtModify.Tables[0].Rows[i]["CPUCore"].ToString(),
                dtModify.Tables[0].Rows[i]["CreatedBy"].ToString(), dtModify.Tables[0].Rows[i]["DefaultLocationID"].ToString(),
                dtModify.Tables[0].Rows[i]["ModelId"].ToString(), dtModify.Tables[0].Rows[i]["UserID"].ToString(), dtModify.Tables[0].Rows[i]["CurrentOwnerID"].ToString(),//Added on 06Mar2013
                dtModify.Tables[0].Rows[i]["AssetId"].ToString(), Convert.ToDateTime(dtModify.Tables[0].Rows[i]["CreatedDate"].ToString()), dtModify.Tables[0].Rows[i]["HostName"].ToString(), dtModify.Tables[0].Rows[i]["CurrentOwner"].ToString(),//Added on 06Mar2013
           dtModify.Tables[0].Rows[i]["Parent"].ToString(), dtModify.Tables[0].Rows[i]["AssetName"].ToString(), dtModify.Tables[0].Rows[i]["CurrentRFIDCardNumber"].ToString(),
             dtModify.Tables[0].Rows[i]["Orientation"].ToString(), dtModify.Tables[0].Rows[i]["StartPos"].ToString(), dtModify.Tables[0].Rows[i]["NoOfRUs"].ToString());

            if (!string.IsNullOrEmpty(dtModify.Tables[0].Rows[i]["CurrentOwnerID"].ToString().Trim()))
                Session["CO"] = Convert.ToInt32(dtModify.Tables[0].Rows[i]["CurrentOwnerID"].ToString().Trim());
            else
                Session["CO"] = 0;

        }

        return DtAsset;
    }


    void ScrollControl()
    {
        if (totrec == 0)
        {
            btnFirst.Enabled = false;
            btnPrevious.Enabled = false;
            btnNext.Enabled = false;
            btnLast.Enabled = false;
        }
        else if (currec >= totrec - 1)
        {
            btnFirst.Enabled = true;
            btnPrevious.Enabled = true;
            btnNext.Enabled = false;
            btnLast.Enabled = false;
        }
        else if (currec <= 0)
        {
            btnFirst.Enabled = false;
            btnPrevious.Enabled = false;
            btnNext.Enabled = true;
            btnLast.Enabled = true;
        }
        else
        {
            btnFirst.Enabled = true;
            btnPrevious.Enabled = true;
            btnNext.Enabled = true;
            btnLast.Enabled = true;

        }
    }
