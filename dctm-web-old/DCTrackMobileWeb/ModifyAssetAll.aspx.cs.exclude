    public void ShowData(int cr)
    {
        DataRow dr = dt.Rows[cr];
        //HIde Location Selection image button (v4.5)
        //Location change will be disabled in Edit Asset and Modify All pages
        Page.ClientScript.RegisterStartupScript(this.GetType(), "script", "disableLocButton();", true);

        CompareItem(ddlBusinessUnit, Convert.ToString(dr["BusinessUnit"]));
        CompareItem(ddlSite, Convert.ToString(dr["Site"]));
        txtLocation.Text = Convert.ToString(dr["Location"]);
        txtAssetID.Text = Convert.ToString(dr["RefNo"]);
        txtRefNo.Text = Convert.ToString(dr["RefNo"]);
        // txtAssetName.Text = Convert.ToString(dr["HostName"]);
        // ddlMfg.SelectedItem.Text = Convert.ToString(dr["Mfg"]);
        ddlMfg.ClearSelection();
        //if (Convert.ToString(dr["Mfg"]) == "")//Added on 06Mar2013
        if (string.IsNullOrEmpty(Convert.ToString(dr["Mfg"])))
        {
            ddlMfg.SelectedIndex = -1;//Added on 06Mar2013 
        }
        else
        {
            CompareItem(ddlMfg, Convert.ToString(dr["Mfg"]));
        }
        if (string.IsNullOrEmpty(Convert.ToString(dr["Model"])))
        {
            txtModel.Text = "No Model";
            hdnModelName.Value = "No Model";
        }
        else
        {
            txtModel.Text = Convert.ToString(dr["Model"]);
            hdnModelName.Value = Convert.ToString(dr["Model"]);
        }

        Hidden1.Value = Convert.ToString(dr["TechCat"]);
        //host names
        // hdnHostNames.Value = dr["AssetName"].ToString() + ",";//Commneted on 07May2013
        hdnHostNames.Value = dr["HostName"].ToString() + ",";//Added on 07May2013
        AddHostsToList();


        if ((Hidden1.Value == ""))
        {
            CompareItem(ddlTechCat, "-Select-");
        }
        else
        {
            CompareItem(ddlTechCat, Convert.ToString(dr["TechCat"]));
        }
        CompareItem(ddlMount, Convert.ToString(dr["RackOrStand"]));
        CompareItem(ddlAssetGroup, Convert.ToString(dr["AssetGroup"]));
        txtOS.Text = Convert.ToString(dr["OS"]);
        txtCPU.Text = Convert.ToString(dr["CPU"]);
        txtCpuCount.Text = Convert.ToString(dr["CpuCount"]);
        txtCPUCore.Text = Convert.ToString(dr["CpuCore"]);
        //txtOwner.Text = Convert.ToString(dr["CreatedBy"]);//Commented on 06Mar2013

        hdnLocID.Value = Convert.ToInt32(dr["DefaultLocationID"]).ToString();
        hdnOwnerID.Value = Convert.ToString(dr["CurrentOwnerID"]);
        hdnOwnerName.Value = Convert.ToString(dr["CurrentOwner"]);//Added on on 06Mar2013
        txtOwner.Text = Convert.ToString(dr["CurrentOwner"]);//Added on on 06Mar2013
        if (dr["ModelId"].ToString() == "")//Added on on 06Mar2013
        {
            hdnModelID.Value = "0";//Added on on 06Mar2013
        }
        else
        {
            hdnModelID.Value = Convert.ToInt32(dr["ModelId"]).ToString();
            //if modelid not equal to zero, get IsBlade details
            objAM = new AssetModelBAL();
            DataSet dsAM = objAM.retrieveByModelID(Int32.Parse(dr["ModelID"].ToString()));
            hdnIsBlade.Value = dsAM.Tables[0].Rows[0][DBFields.DBFIELD_IS_BLADE].ToString();//IsBlade
        }
        hdnAssetID.Value = Convert.ToInt32(dr["AssetId"]).ToString();
        wdcCreatedDate.Value = Convert.ToDateTime(dr["AssetCreatedDate"].ToString());


        //*Added on on 07May2013
        txtParentAsset.Text = Convert.ToString(dr["Parent"]);
        txtAssetNameA.Text = Convert.ToString(dr["AssetName"]);//*


        //v3.8
        // show remove parent only when parent exists.
        if (!string.IsNullOrEmpty(txtParentAsset.Text))
        {
            imgRemoveParent.Visible = true;
            //hide imgLocButton if parent exists
            //string script = "<script type='text/javascript'>disableLocButton();</script>";
            //ClientScript.RegisterClientScriptBlock(this.GetType(), "DisableLocButton", script,false);
            Page.ClientScript.RegisterStartupScript(this.GetType(), "script", "disableLocButton();", true);
        }


        //v3.8 -- kjb o 04 june 2013
        txtBarcode.Text = dr["CurrentRFIDCardNumber"].ToString();

        //--end
        //*V3.8-Added on 16Oct2013-By Amar Vidya
        if (!string.IsNullOrEmpty(dr["Orientation"].ToString()))
        {
            ddlOrientation.SelectedItem.Text = dr["Orientation"].ToString();
        }
        if (!string.IsNullOrEmpty(dr["StartPos"].ToString()))
        {
            if (dr["StartPos"].ToString().Trim().CompareTo("0") != 0)
            {
                Session["StartPos"] = dr["StartPos"].ToString();
                ddlPosition.SelectedValue = dr["StartPos"].ToString();
            }
            else
            {
                ddlPosition.SelectedIndex = 0;
            }
        }
        if (!string.IsNullOrEmpty(dr["NoOfRUs"].ToString()))
        {
            if (dr["NoOfRUs"].ToString().Trim().CompareTo("0") != 0)
            {
                Session["NoOfRUs"] = dr["NoOfRUs"].ToString(); ;
                ddlNoOfRU.SelectedValue = dr["NoOfRUs"].ToString();
            }
            else
            {
                ddlNoOfRU.SelectedIndex = 0;
            }
        }//*
    }


