        DtAsset.Columns.Add(dc);
        dc = new DataColumn("AssetCreatedDate", typeof(DateTime));
        DtAsset.Columns.Add(dc);
        dc = new DataColumn("HostName", typeof(string));
        DtAsset.Columns.Add(dc);
        dc = new DataColumn("CurrentOwner", typeof(string));//Added on 06Mar2013
        DtAsset.Columns.Add(dc);
        //*Added on 07May2013
        dc = new DataColumn("Parent", typeof(string));
        DtAsset.Columns.Add(dc);
        dc = new DataColumn("AssetName", typeof(string));
