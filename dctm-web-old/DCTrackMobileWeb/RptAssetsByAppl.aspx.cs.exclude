    // J00007 by kjb on 25 Sep 2012
    # region new control declaration
    protected DropDownList ddlApplType, ddlApplCriticality, ddlApplDivision, ddlApplVendor, ddlApplStatus,ddlBusinessUnit,ddlPrimarySite;
    protected TextBox txtParentLocation;
    # endregion

    protected void Page_Load(object sender, EventArgs e)
    {
        // J00007 by kjb on 25 Sep 2012
        # region New controls initialization
        ddlBusinessUnit = (DropDownList)this.wpSearchOptions.Groups[0].Items[0].FindControl("ddlBusinessUnit");
        ddlPrimarySite = (DropDownList)this.wpSearchOptions.Groups[0].Items[0].FindControl("ddlPrimarySite");
        ddlApplType = (DropDownList)this.wpSearchOptions.Groups[0].Items[0].FindControl("ddlApplType");
        ddlApplCriticality = (DropDownList)this.wpSearchOptions.Groups[0].Items[0].FindControl("ddlApplCriticality");
        ddlApplDivision = (DropDownList)this.wpSearchOptions.Groups[0].Items[0].FindControl("ddlApplDivision");
        ddlApplVendor = (DropDownList)this.wpSearchOptions.Groups[0].Items[0].FindControl("ddlApplVendor");
        ddlApplStatus = (DropDownList)this.wpSearchOptions.Groups[0].Items[0].FindControl("ddlApplStatus");

        txtParentLocation = (TextBox)this.wpSearchOptions.Groups[0].Items[0].FindControl("txtParentLocation");

        # endregion

        _dtRights = (DataTable)(Session["Rights"]);

        if (_dtRights == null)
        {
            Session["RedirectUrl"] = "RptAssetsByAppl.aspx";
            Response.Redirect("Login.aspx");
        }

        bool blfoundPage = false;

        if (_dtRights.Select("Module = 'Assets By Application' and Rights = '" + "View" + "'").Length != 0)
        {
            blfoundPage = true;
        }

        if (blfoundPage == false)
        {
            Response.Redirect("AccessDeniedPage.aspx");
            return;
        }

        if (!Page.IsPostBack)
        {
            FillDropDownLists();
            populateApplTypeList();
            populateApplCriticalityList();
            populateManageList();
        }
    }


    private void populateApplTypeList()
    {
        objAT = new iAssetTrack.BAL.ApplicationTypeBAL();
        DataSet dsAT = objAT.retrieve();
        DataTable dtAT = dsAT.Tables[0];

        DataRow dr = dtAT.NewRow();
        dr[0] = 0;
        dr[1] = "(All)";
        dtAT.Rows.InsertAt(dr, 0);

        ddlApplType.DataSource = dtAT;
        ddlApplType.DataValueField = dtAT.Columns[0].ToString();
        ddlApplType.DataTextField = dtAT.Columns[1].ToString();
        ddlApplType.DataBind();
    }

    private void populateApplCriticalityList()
    {
        objAC = new iAssetTrack.BAL.ApplicationCriticalityBAL();
        DataSet dsAC = objAC.retrieve();
        DataTable dtAC = dsAC.Tables[0];

        DataRow dr = dtAC.NewRow();
        dr[0] = 0;
        dr[1] = "(All)";
        dtAC.Rows.InsertAt(dr, 0);

        ddlApplCriticality.DataSource = dtAC;
        ddlApplCriticality.DataValueField = dtAC.Columns[0].ToString();
        ddlApplCriticality.DataTextField = dtAC.Columns[1].ToString();
        ddlApplCriticality.DataBind();
    }

    private void populateDivisionList(int BusinessUnitID)
    {
        objDiv = new iAssetTrack.BAL.DivisionBAL();
        DataSet dsDiv = objDiv.retrieveByBusinessUnitId(BusinessUnitID);
        DataTable dtDiv = dsDiv.Tables[0];

        DataRow dr = dtDiv.NewRow();
        dr[0] = 0;
        dr[1] = "(All)";
        dtDiv.Rows.InsertAt(dr, 0);

        ddlApplDivision.DataSource = dtDiv;
        ddlApplDivision.DataValueField = dtDiv.Columns[0].ToString();
        ddlApplDivision.DataTextField = dtDiv.Columns[1].ToString();
        ddlApplDivision.DataBind();
    }

    private void populateManageList()
    {
        objMfg = new iAssetTrack.BAL.ManufacturerBAL();
        DataSet dsMfg = objMfg.retrieve();
        DataTable dtMfg = dsMfg.Tables[0];

        DataRow dr = dtMfg.NewRow();
        dr[0] = 0;
        dr[1] = "(All)";
        dtMfg.Rows.InsertAt(dr, 0);

        ddlApplVendor.DataSource = dtMfg;
        ddlApplVendor.DataValueField = dtMfg.Columns[0].ToString();
        ddlApplVendor.DataTextField = dtMfg.Columns[1].ToString();
        ddlApplVendor.DataBind();
    }





    private void FillDropdownsByBU()
    {
        int intBusinessUnitID = 0;
        if (ddlBusinessUnit.SelectedValue != "")
            intBusinessUnitID = Convert.ToInt32(ddlBusinessUnit.SelectedValue);
        FillDropDownList(StoredProcedures.SP_SITEBYBU_LIST, ref ddlPrimarySite, intBusinessUnitID);

    }

    private void FillDropDownList(string strStoredProc, ref DropDownList ddl, int id)
    {
        //ICommon svc = (ICommon)RemotingHelper.CreateProxy(typeof(ICommon));
        iAssetTrack.BAL.CommonBAL objCommon = new iAssetTrack.BAL.CommonBAL();
        DataTable dt = objCommon.FillDropDownList(strStoredProc, "(All)", id);
        ddl.DataSource = dt;
        ddl.DataValueField = dt.Columns[0].ToString();
        ddl.DataTextField = dt.Columns[1].ToString();
        ddl.DataBind();
    }



