    protected void btnShow_Click(object sender, Infragistics.WebUI.WebDataInput.ButtonEventArgs e)
    {
        //-- total 8 parameters
        //param1
        parm[0] = new ReportParameter("BusinessUnitID", ddlBusinessUnit.SelectedItem.Value.ToString());
        //param 2
        if (ddlPrimarySite.SelectedIndex > 0)
            parm[1] = new ReportParameter("SiteID", ddlPrimarySite.SelectedItem.Value.ToString());
        else
            parm[1] = new ReportParameter("SiteID", ddlPrimarySite.SelectedIndex.ToString());
        //param 3
        int intLocation = 0;
        //if (ddlLocation.CurrentValue != null)
        //{
        //    if (ddlLocation.SelectedItemIndex > 0 || Utility.ISNumeric(ddlLocation.CurrentValue))
        //        intLocation = Convert.ToInt32(Utility.ISNumeric(ddlLocation.CurrentValue) ? ddlLocation.CurrentValue : ddlLocation.SelectedValue);
        //}
        if (!string.IsNullOrEmpty(txtParentLocation.Text.Trim()))
        {
            if (!txtParentLocation.Text.Equals("(All)"))
            {
                if (!string.IsNullOrEmpty(hdnParentLocationID.Value))
                    intLocation = int.Parse(hdnParentLocationID.Value.ToString());
            }
            else
            {
                intLocation = 0;
            }
        }

        parm[2] = new ReportParameter("LocationID", intLocation.ToString());
        //param 4
        if (ddlApplType.SelectedIndex > 0)
            parm[3] = new ReportParameter("ApplType", ddlApplType.SelectedItem.Value.ToString());
        else
            parm[3] = new ReportParameter("ApplType", ddlApplType.SelectedIndex.ToString());
        //param 5
        if (ddlApplCriticality.SelectedIndex > 0)
            parm[4] = new ReportParameter("ApplCriticality", ddlApplCriticality.SelectedItem.Value.ToString());
        else
            parm[4] = new ReportParameter("ApplCriticality", ddlApplCriticality.SelectedIndex.ToString());
        //param 6
        if (ddlApplStatus.SelectedIndex > 0)
            parm[5] = new ReportParameter("ApplStatus", ddlApplStatus.SelectedItem.Value.ToString());
        else
            parm[5] = new ReportParameter("ApplStatus", ddlApplStatus.SelectedIndex.ToString());
        //param 7
        if (ddlApplDivision.SelectedIndex > 0)
            parm[6] = new ReportParameter("ApplDivision", ddlApplDivision.SelectedItem.Value.ToString());
        else
            parm[6] = new ReportParameter("ApplDivision", ddlApplDivision.SelectedIndex.ToString());
        //param 8
        if (ddlApplVendor.SelectedIndex > 0)
            parm[7] = new ReportParameter("ApplVendor", ddlApplVendor.SelectedItem.Value.ToString());
        else
            parm[7] = new ReportParameter("ApplVendor", ddlApplVendor.SelectedIndex.ToString());

        this.ReportViewer1.Reset();
        this.ReportViewer1.AsyncRendering = false;
        this.ReportViewer1.ShowCredentialPrompts = false;
        this.ReportViewer1.ShowParameterPrompts = false;
        this.ReportViewer1.ProcessingMode = Microsoft.Reporting.WebForms.ProcessingMode.Remote;

        this.ReportViewer1.ServerReport.ReportServerCredentials = new ReportCredentials("Reportfolder Name", "Password of the folder", "");
        this.ReportViewer1.ServerReport.ReportServerUrl = new System.Uri(ConfigurationManager.AppSettings["ReportServerUrl"]);
        this.ReportViewer1.ServerReport.ReportPath = ConfigurationManager.AppSettings["ReportServerFolder"] + "AssetsByApplications";
        this.ReportViewer1.ServerReport.SetParameters(parm);
        this.ReportViewer1.ServerReport.Refresh();
        this.ReportViewer1.Visible = true;
        parm = null;

    }
}
