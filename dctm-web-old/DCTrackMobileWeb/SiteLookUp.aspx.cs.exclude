    /// <summary>    
    /// Used to initialize grid row. 
    /// </summary>
    /// <author>Venkatesh</author>
    /// <createdOn>29 September 2006</createdOn>
    protected void UWGSubCon_InitializeRow(object sender, Infragistics.WebUI.UltraWebGrid.RowEventArgs e)
    {
        string strSubCon = e.Row.Cells[1].Text.Replace("'", "~~~");
        e.Row.Cells[1].Text = "<div><a href=" + "javascript:userSelected('" + e.Row.Cells[0].Text + "','" + strSubCon.Replace(" ", "%20") + "');>" + e.Row.Cells[1].Text + "</a></div>";

        //e.Row.Cells[1].Text = "<div><a href="+"javascript:selectSubcontractor('" + e.Row.Cells[0].Text + "','" + e.Row.Cells[1].Text.Replace(" ","%20")+"');>" + e.Row.Cells[1].Text + "</a></div>";
    }

    /// <summary>    
    /// Used to call when grid page index changes. 
    /// </summary>
    /// <author>Venkatesh</author>
    /// <createdOn>29 September 2006</createdOn>
    protected void UWGSubCon_PageIndexChanged(object sender, Infragistics.WebUI.UltraWebGrid.PageEventArgs e)
    {
        this.FillGrid(e.NewPageIndex);
    }
