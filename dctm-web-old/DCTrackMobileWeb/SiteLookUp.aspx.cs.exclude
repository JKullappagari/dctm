        //    {
        //        ddlBusinessUnit.SelectedValue = search;
        //        ddlBusinessUnit.Enabled = true;
                
        //    }
        //    else
        //    {
        //        ddlBusinessUnit.Enabled = true;
        //    }

        //}
        //else
        //    search = null;

        this.UWGSubCon.DisplayLayout.Pager.PageSize = Int32.Parse(System.Configuration.ConfigurationManager.AppSettings["PageSize"].ToString());
        this.UWGSubCon.DisplayLayout.Pager.AllowPaging = true;
    }

    /// <summary>
    /// This method is used to populate the business unit drop down list 
    /// to search subcontractors
    /// </summary>
    /// <author>Venkatesh</author>
    /// <createdOn>29 September 2006</createdOn>
    private void LoadBusinessUnits()
    {
       int intUserID = 0;
        if (Session["UserID"] != null)
            intUserID = Convert.ToInt32(Session["UserID"].ToString());

        FillDropDownListBU(StoredProcedures.SP_BUSINESSUNIT_LISTBYUSERID, ref ddlBusinessUnit, intUserID);
    }

    /// <summary>    
    /// Used to reset the selected value.
    /// </summary>
    /// <author>Venkatesh</author>
    /// <createdOn>29 September 2006</createdOn>
    /// 
    

    protected void wibReset_Click(object sender, Infragistics.WebUI.WebDataInput.ButtonEventArgs e)
    {
        string strStartUpScript = "<script language='javascript' type='text/javascript'>userSelected('','');</script>";
        Page.ClientScript.RegisterStartupScript(typeof(Page), "PopupScript", strStartUpScript);
       
    }

    /// <summary>    
    /// Used to fill BU dropdown list. 
    /// </summary>
    /// <author>Venkatesh</author>
    /// <createdOn>29 September 2006</createdOn>
    private void FillDropDownListBU(string strStoredProc, ref DropDownList ddl, int id)
    {

        CommonBAL svc = new CommonBAL();
        //ICommon svc = (ICommon)RemotingHelper.CreateProxy(typeof(ICommon));

        DataTable dt = svc.FillDropDownListBU(strStoredProc, "", id);
        ddl.DataSource = dt;
        ddl.DataValueField = dt.Columns[0].ToString();
        ddl.DataTextField = dt.Columns[1].ToString();
        ddl.DataBind();
    }

    /// <summary>    
    /// Used to search with input. 
    /// </summary>
    /// <author>Venkatesh</author>
    /// <createdOn>29 September 2006</createdOn>
    protected void wibSearch_Click(object sender, Infragistics.WebUI.WebDataInput.ButtonEventArgs e)
    {
        UWGSubCon.DisplayLayout.Pager.CurrentPageIndex = 1;
        this.FillGrid(0);
    }

    /// <summary>    
    /// Used to fill grid with result. 
    /// </summary>
    /// <author>Venkatesh</author>
    /// <createdOn>29 September 2006</createdOn>
    private void FillGrid(int iPageIndex)
    {
        if (ddlBusinessUnit.SelectedValue == "")
            return;
        if (ddlSite.SelectedValue == "")
            return;

        //Initialize the Subcontractor Class
        //ISubConCreation svc = (ISubConCreation)RemotingHelper.CreateProxy(typeof(ISubConCreation));

        // Fill the Location List
        LocationBAL ObjLocation = new LocationBAL();
        int intLocationID = 0;
        string LocationName = "";

        if (ddlSite.SelectedValue != "")
            ObjLocation.SiteID = Convert.ToInt32(ddlSite.SelectedValue);

        DataSet ds = ObjLocation.GetLocationBYSite();

        if (ds.Tables[0].Rows.Count > 0)
        {
            if ((ds.Tables[0].Rows[0][0] != null) && (ds.Tables[0].Rows[0][0].ToString() != ""))
            {
                intLocationID = Convert.ToInt32(ds.Tables[0].Rows[0][0].ToString());
                LocationName = ds.Tables[0].Rows[0][1].ToString();
            }
        }
        
        if (iPageIndex == 0)
            iPageIndex = 1;

        this.UWGSubCon.DisplayLayout.Pager.AllowPaging = true;


        this.UWGSubCon.DataSource = ds.Tables[0].DefaultView;
        this.UWGSubCon.DataBind();

        if (UWGSubCon.Rows.Count <= 0 && UWGSubCon.DisplayLayout.Pager.PageCount > 0)
            if (UWGSubCon.DisplayLayout.Pager.CurrentPageIndex > 1)
            {
                UWGSubCon.DisplayLayout.Pager.CurrentPageIndex = iPageIndex - 1;
                UWGSubCon.DataBind();
            
            }


        // Disable paging if there aren't enough rows for more than one page
        if (ds.Tables[0].Rows.Count <= Int32.Parse(System.Configuration.ConfigurationManager.AppSettings["PageSize"].ToString()))
            this.UWGSubCon.DisplayLayout.Pager.AllowPaging = false;


        //this.UWGSubCon.Columns[0].Hidden = true;
        this.UWGSubCon.Columns[1].Width = Unit.Pixel(378);
        UWGSubCon.Visible = true;
    }

