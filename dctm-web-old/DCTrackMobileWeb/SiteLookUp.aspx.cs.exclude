    protected void ddlBusinessUnit_SelectedIndexChanged(object sender, EventArgs e)
    {
        //throw new Exception("The method or operation is not implemented.");
        // Call the BAL to get the list of sites

        LoadSiteList();
    }



    private void LoadSiteList()
    {
        SitesBAL ObjSite = new iAssetTrack.BAL.SitesBAL();
        DataSet ds = ObjSite.retrieveByBusinessUnitId(Convert.ToInt32(this.ddlBusinessUnit.SelectedValue));
        DataTable dt = ds.Tables[0];
        ddlSite.DataSource = dt;
        ddlSite.DataValueField = dt.Columns[0].ToString();
        ddlSite.DataTextField = dt.Columns[1].ToString();
        ddlSite.DataBind();
        UpdatePanelSite.Update();
    }

    protected void Page_Load(object sender, EventArgs e)
    {
        //Infragistics.WebUI.Shared.Util.ClientScript.ResolveAndRegisterClientScriptInclude("../Scripts/ig_webgrid_an.js","","../Scripts/ig_webgrid_an.js","ig_webgrid_an.js",this.WebCombo1,"ig_webgrid_an");

        if (Request.QueryString["NameField"] != "")
        {
            this.NameField = Request.QueryString["NameField"].ToString();
        }

        if (Request.QueryString["IDField"] != "")
        {
            this.IDField = Request.QueryString["IDField"].ToString();
        }



        if (!Page.IsPostBack)
        {
            Response.Cache.SetCacheability(HttpCacheability.NoCache);
            //hide the grid
            UWGSubCon.Visible = false;
            //load search values
            LoadBusinessUnits();
            LoadSiteList();
        }


        if (Request.QueryString["BusinessUnit"] != "")
        {
            string BUInput = Request.QueryString["BusinessUnit"];
            if(ddlBusinessUnit.Items.FindByValue(BUInput) != null)
            {
                ddlBusinessUnit.SelectedValue = BUInput;
                ddlBusinessUnit.Enabled = false;
               
            }
        }

        //Check if we have a serch, or if this is a normal page_load
        //string search="0";

        //if (Request.QueryString.Count>0)
