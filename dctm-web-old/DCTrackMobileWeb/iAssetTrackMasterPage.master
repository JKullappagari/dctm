                    <%--<asp:HyperLink ID="hlLogout" runat="server" ImageUrl="~/images/WindowClose_32.png"
                        NavigateUrl="~/LogoutMe.aspx"></asp:HyperLink>--%>
                    <asp:HyperLink ID="lnkHelp" Target="_blank" runat="server" ForeColor="White" NavigateUrl="~/HelpFiles/index.html">
