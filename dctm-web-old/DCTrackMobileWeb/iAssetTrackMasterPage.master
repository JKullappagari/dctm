<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Transitional//EN">
<html xmlns="http://www.w3.org/1999/xhtml">
<head id="Head1" runat="server">
    <title>DCTrackMobileWeb</title>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <link href="css/text.css" rel="stylesheet" type="text/css" />
    <link href="css/jquery-ui-1.12.1.custom/jquery-ui.css" rel="stylesheet" type="text/css" />
    <link rel="shortcut icon" type="image/x-icon" href="images/favicon.ico" />
    <script type="text/javascript" src="Scripts/jquery-2.0.0.js"></script>
    <script type="text/javascript" src="Scripts/jquery-ui.min.js"></script>
    <script src="Scripts/JScript.js" type="text/javascript"></script>
    <script type="text/javascript">
        var validNavigation = false;
        var lastkey;
        var keynum;
        var leave_message = 'Are you sure want to leave?'

        function goodbye(e) {

            var hdnSrcTarget = $("#__EVENTTARGET")[0];
            if (hdnSrcTarget != null && hdnSrcTarget != 'undefined') {
                if (hdnSrcTarget.value == '')
                    isPostBack = false;
                else
                    isPostBack = true;
            }

            var condition = !(validNavigation || isPostBack)

            if (condition) {
                var mywindow = window.open("logoutme.aspx", "", "width=200, height=100");
                mywindow.close();

//                if (!e) e = window.event;
//                //e.cancelBubble is supported by IE - this will kill the bubbling process.
//                e.cancelBubble = true;
//                e.returnValue = leave_message;
//                //e.stopPropagation works in Firefox.
//                if (e.stopPropagation) {
//                    e.stopPropagation();
//                    e.preventDefault();
//                }
//                //return works for Chrome and Safari
//                return leave_message;
            }

        }


//        window.onbeforeunload = goodbye;

        function wireUpEvents() {

            // Attach the event keypress to exclude the F5 refresh
            $(document).bind('keypress', function (e) {
                if (e.keyCode == 116) {
                    validNavigation = true;
                }
                // Capture and remap F-key
                keynum = e.keyCode;
                if (lastkey == 18 && keynum == 115)
                    validNavigation = false;

                lastkey = keynum;

            });

            // Attach the event click for all links in the page
            $("a").bind("click", function () {
                validNavigation = true;
            });

            // Attach the event submit for all forms in the page
            $("form").bind("submit", function () {
                validNavigation = true;
            });

            // Attach the event when the dropdown option is changed
            $("select#dropdownId").bind("change", function () {
                validNavigation = true;
            });

            // Attach the event click for all inputs in the page
            $("input[type=submit]").bind("click", function () {
                validNavigation = true;
            });

            $('a:not(a[href^=javascript])').click(function () {
                validNavigation = true;
            });

            $("input:image").click(function () {
                validNavigation = true;
            });

        }

        // Wire up the events as soon as the DOM tree is ready
        $(document).ready(function () {
            wireUpEvents();
        });

        function MenuItem_CLick(menu, eventArgs) {
            validNavigation = true;
        }

    </script>
    <style type="text/css">
        .style1
        {
            width: 100%;
        }
        .style3
        {
            width: 80%;
        }
        .style4
        {
            width: 482px;
        }
        .style5
        {
            width: 238px;
        }
        .style6
        {
            width: 194px;
        }
        .body
        {
            padding: 0;
        }
        .content
        {
            position: absolute;
            width: 100%;
            bottom: 20px;
        }
        .footer
        {
            text-align: center;
            position: absolute;
            height: 20px;
            bottom: 0;
        }
        .disabled
        {
            display: none;
        }
        
        .enabled
        {
            display: inline;
        }
    </style>
</head>
<body style="margin-left: 0px; margin-right: 0px; margin-top: 0px; margin-bottom: 0px;
