    protected void btnShow_Click(object sender, Infragistics.WebUI.WebDataInput.ButtonEventArgs e)
    {
        //param 1
        if (ddlTechCat.SelectedIndex > 0)
            parm[0] = new ReportParameter("TechCat", ddlTechCat.SelectedItem.Text);
        else
            parm[0] = new ReportParameter("TechCat", ddlTechCat.SelectedIndex.ToString());

        //param 2
        if (ddlRackOrStand.SelectedIndex > 0)
            parm[1] = new ReportParameter("RackOrStand", ddlRackOrStand.SelectedItem.Text);
        else
            parm[1] = new ReportParameter("RackOrStand", ddlRackOrStand.SelectedIndex.ToString());

        //param 3

        parm[2] = new ReportParameter("BU", ddlBusinessUnit.SelectedItem.Value.ToString());

        //param 4
        if (ddlPrimarySite.SelectedIndex > 0)
            parm[3] = new ReportParameter("Site", ddlPrimarySite.SelectedItem.Value.ToString());
        else
            parm[3] = new ReportParameter("Site", ddlPrimarySite.SelectedIndex.ToString());

        //param 5
        int intLocation = 0;
        if (!string.IsNullOrEmpty(txtParentLocation.Text.Trim()))
        {
            if (!txtParentLocation.Text.Equals("(All)"))
            {
                if (!string.IsNullOrEmpty(hdnParentLocationID.Value))
                    intLocation = int.Parse(hdnParentLocationID.Value.ToString());
            }
            else
            {
                intLocation = 0;
            }
        }
        parm[4] = new ReportParameter("Loc", intLocation.ToString());

        this.ReportViewer1.Reset();
        this.ReportViewer1.AsyncRendering = false;
        this.ReportViewer1.ShowCredentialPrompts = false;
        this.ReportViewer1.ShowParameterPrompts = false;
        this.ReportViewer1.ProcessingMode = Microsoft.Reporting.WebForms.ProcessingMode.Remote;

        this.ReportViewer1.ServerReport.ReportServerCredentials = new ReportCredentials("Reportfolder Name", "Password of the folder", "");
        this.ReportViewer1.ServerReport.ReportServerUrl = new System.Uri(ConfigurationManager.AppSettings["ReportServerUrl"]);
        this.ReportViewer1.ServerReport.ReportPath = ConfigurationManager.AppSettings["ReportServerFolder"] + "SPCModelCountBySite";
        this.ReportViewer1.ServerReport.SetParameters(parm);
        this.ReportViewer1.ServerReport.Refresh();
        this.ReportViewer1.Visible = true;
        parm = null;

        //this.wpSearchOptions.Expanded = false;//J00007 by kjb on 26 Sep 2012
        this.wpSearchOptions.Groups[0].Expanded = false;
    }
}
