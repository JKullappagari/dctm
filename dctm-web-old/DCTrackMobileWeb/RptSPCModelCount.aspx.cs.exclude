    protected void Page_Load(object sender, EventArgs e)
    {

        // J00007 by kjb on 26 Sep 2012
        # region New controls initialization
        ddlBusinessUnit = (DropDownList)this.wpSearchOptions.Groups[0].Items[0].FindControl("ddlBusinessUnit");
        ddlPrimarySite = (DropDownList)this.wpSearchOptions.Groups[0].Items[0].FindControl("ddlPrimarySite");
        ddlMfg = (DropDownList)this.wpSearchOptions.Groups[0].Items[0].FindControl("ddlMfg");
        ddlRackOrStand = (DropDownList)this.wpSearchOptions.Groups[0].Items[0].FindControl("ddlRackOrStand");
        ddlTechCat = (DropDownList)this.wpSearchOptions.Groups[0].Items[0].FindControl("ddlTechCat");
        txtParentLocation = (TextBox)this.wpSearchOptions.Groups[0].Items[0].FindControl("txtParentLocation");

        # endregion


        Session["PageHeader"] = "SPC Model Count Report";
        _dtRights = (DataTable)(Session["Rights"]);

        if (_dtRights == null)
        {
            Session["RedirectUrl"] = "RptSPCModelCount.aspx";
            Response.Redirect("Login.aspx");
        }

        bool blfoundPage = false;

        if (_dtRights.Select("Module = 'SPC Model Count Report' and Rights = '" + "View" + "'").Length != 0)
        {
            blfoundPage = true;
        }

        if (blfoundPage == false)
        {
            Response.Redirect("AccessDeniedPage.aspx");
            return;
        }

        if (!Page.IsPostBack)
        {
            // report viewer settings

            // fill drop down lists
            FillDropDownLists();
            FillDropDownLists(StoredProcedures.SP_TECHCAT_LIST, ddlTechCat);
            ddlBusinessUnit.SelectedIndex = 1;
            ddlBusinessUnit.Enabled = false;
            FillDropdownsByBU();

        }


    }


    private void FillDropDownLists(string strStoredProc, DropDownList ddl)
    {
        TechCatBAL objTechCat = new TechCatBAL();
        DataSet dsTC = objTechCat.retrieve();
        DataTable dtTC = dsTC.Tables[0];

        DataRow dr = dtTC.NewRow();
        dr[0] = "0";
        dr[1] = "(All)";
        dtTC.Rows.InsertAt(dr, 0);

        ddl.DataSource = dtTC;
        ddl.DataValueField = dtTC.Columns[0].ToString();
        ddl.DataTextField = dtTC.Columns[1].ToString();
        ddl.DataBind();
    }


   
    private void FillDropdownsByBU()
    {
        int intBusinessUnitID = 0;
        if (ddlBusinessUnit.SelectedValue != "")
            intBusinessUnitID = Convert.ToInt32(ddlBusinessUnit.SelectedValue);
        FillDropDownList(StoredProcedures.SP_SITEBYBU_LIST, ref ddlPrimarySite, intBusinessUnitID);
        txtParentLocation.Text = "(All)";
        hdnParentLocationID.Value = "0";
    }

    private void FillDropDownList(string strStoredProc, ref DropDownList ddl, int id)
    {
        //ICommon svc = (ICommon)RemotingHelper.CreateProxy(typeof(ICommon));
        iAssetTrack.BAL.CommonBAL objCommon = new iAssetTrack.BAL.CommonBAL();
        DataTable dt = objCommon.FillDropDownList(strStoredProc, "(All)", id);
        ddl.DataSource = dt;
        ddl.DataValueField = dt.Columns[0].ToString();
        ddl.DataTextField = dt.Columns[1].ToString();
        ddl.DataBind();
    }



