                                                            </asp:DropDownList>
                                                        </td>
                                                        <td class="labelTD" style="height: 17px;" valign="top">
                                                            <asp:Label ID="lblTechCat" runat="server" CssClass="FieldName" meta:resourcekey="lblTechCatResource1"
                                                                Width="89px"></asp:Label>
                                                        </td>
                                                        <td class="ControlTD" style="height: 17px;" valign="bottom">
                                                            <asp:DropDownList ID="ddlTechCat" runat="server" CssClass="dropdownText" meta:resourcekey="ddlTechCatResource1"
                                                                TabIndex="7" Width="156px">
                                                            </asp:DropDownList>
                                                        </td>
                                                        <td class="labelTD" style="height: 17px;" valign="bottom">
                                                        </td>
                                                    </tr>
                                                    <tr style="height: 19px">
                                                        <td class="labelTD" style="height: 19px;">
                                                            
                                                        </td>
                                                        <td class="ControlTD" style="height: 15px;" valign="top">
                                                            
                                                        </td>
                                                        <td class="labelTD" style="height: 19px;">
                                                            
                                                        </td>
                                                        <td class="ControlTD" style="height: 19px;">
                                                            
                                                        </td>
                                                        <td class="labelTD" style="height: 19px;">
                                                            
                                                        </td>
                                                    </tr>
                                                    <tr style="height: 19px">
                                                        <td class="labelTD" style="height: 19px;">
                                                            <asp:Label ID="lblMFG" runat="server" width="150px" CssClass="FieldName" meta:resourcekey="MFGResource1"></asp:Label>
                                                        </td>
                                                        <td class="ControlTD" style="height: 19px;">
                                                            <asp:DropDownList ID="ddlMFG" runat="server" CssClass="dropdownText" meta:resourcekey="ddlMFGResource1"
                                                                TabIndex="7" Width="156px" AutoPostBack="True" OnSelectedIndexChanged="ddlMFG_SelectedIndexChanged">
                                                            </asp:DropDownList>
                                                        </td>
                                                        <td class="labelTD" style="height: 19px;" valign="top">
                                                            <asp:Label ID="lblModel" runat="server" width="150px" CssClass="FieldName" meta:resourcekey="ModelResource1"></asp:Label>
                                                        </td>
                                                        <td class="ControlTD" style="height: 19px;">
                                                            <asp:TextBox ID="txtModel" runat="server" Width="154px" CssClass="FieldValue" Enabled="False"
                                                                MaxLength="150" TabIndex="6" Height="16px" Text="(All)" meta:resourcekey="txtModelResource1"></asp:TextBox>
                                                        </td>
                                                        <td class="ControlTD" style="height: 29px; width: 1766px;" valign="top">
                                                            <a href="javascript:openModelList('TreeList.aspx?Type=SearchModels&MfgName=<%=ddlMFG.SelectedItem.Text %>&MfgID=<%=ddlMFG.SelectedItem.Value %>&BU=<%=ddlBusinessUnit.SelectedItem.Value %>&Header=AssetModel');">
                                                                <img id="img1" alt="Load List" src="images/search.gif" style="border: 0;" /></a>
