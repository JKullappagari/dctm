    protected void ddlSheetName_SelectedIndexChanged(object sender, EventArgs e)
    {
        ddlSourceCol1.Items.Clear();
        ddlSourceCol2.Items.Clear();
        ddlSourceCol3.Items.Clear();
        ddlSourceCol4.Items.Clear();
        ddlSourceCol5.Items.Clear();
        ddlSourceCol6.Items.Clear();
        ddlSourceCol7.Items.Clear();
        ddlSourceCol8.Items.Clear();
        ddlSourceCol9.Items.Clear();
        ddlSourceCol10.Items.Clear();
        ddlSourceCol11.Items.Clear();
        ddlSourceCol12.Items.Clear();
        //*Added on 8May2013
        ddlSourceCol13.Items.Clear();
        ddlSourceCol14.Items.Clear();//*

        if (ddlSheetName.SelectedIndex > 0)
        {
            Panel1.Enabled = true;

            //LoadSourceExcelColumnHeaderNames(Session["SavePath"].ToString(), ddlSheetName.SelectedItem.Text.ToString());//Commented on 8Apr2013
            // LoadSourceExcelColumnHeaderNames(Session["SavePath"].ToString(), ddlSheetName.SelectedItem.Text.ToString() + "$");//Added on 8Apr2013
            LoadSourceExcelColumnHeaderNames(Session["SavePath"].ToString(), ddlSheetName.SelectedItem.Value.ToString());//Added on 8Apr2013

        }
        else
        {
            Panel1.Enabled = false;
        }
        ddlSheetName.Enabled = true;

        SessionClear();//Added on 8Apr2013
        ddlTemplateDisable();//Added on 8Apr2013
    }


