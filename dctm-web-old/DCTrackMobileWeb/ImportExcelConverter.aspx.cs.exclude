    //*Added on 08Oct2013
   
    private void CopyColumns(DataTable source, DataTable dest)
    {
        if (Session["listTempSelColNames"] != null)
        {
            listTempSelColNames = (List<string>)Session["listTempSelColNames"];
        }
        foreach (DataRow sourcerow in source.Rows)
        {
            DataRow destRow = dest.NewRow();
            foreach (string colname in listSelColNames1)
            {
                destRow[colname] = sourcerow[colname];
            }
            dest.Rows.Add(destRow);
        }
    }
 
