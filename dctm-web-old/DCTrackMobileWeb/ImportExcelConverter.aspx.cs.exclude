    public void ExportToExcel(DataTable dt)
    {

        if (dt.Rows.Count > 0)
        {

            string filename = "ConvertedExcel.xls";

            System.IO.StringWriter tw = new System.IO.StringWriter();

            System.Web.UI.HtmlTextWriter hw = new System.Web.UI.HtmlTextWriter(tw);

            DataGrid dgGrid = new DataGrid();

            dgGrid.DataSource = dt;

            dgGrid.DataBind();



            dgGrid.RenderControl(hw);

            Response.ContentType = "application/msexcel";

            Response.AppendHeader("Content-Disposition", "attachment; filename=" + filename + "");

            this.EnableViewState = false;

            Response.Write(tw.ToString());

            Response.End();

        }

    }

    public void ExportToExcel1(DataSet ds)
    {
        Infragistics.Documents.Excel.Workbook workbook = new Infragistics.Documents.Excel.Workbook();

        Infragistics.Documents.Excel.Worksheet worksheet = workbook.Worksheets.Add("Assets");//Added on 8Apr2013
        foreach (DataTable table in ds.Tables)
        {

            // Create the worksheet to represent this data table
            //Infragistics.Documents.Excel.Worksheet worksheet = workbook.Worksheets.Add(table.TableName);//Commented on 8Apr2013
            //Infragistics.Documents.Excel.Worksheet worksheet = workbook.Worksheets.Add(table.TableName.Replace("'", string.Empty).ToString().Trim());//Added on 8Apr2013

            //Infragistics.Documents.Excel.Worksheet worksheet = workbook.Worksheets.Add("Sheet1");//Added on 8Apr2013



            for (int columnIndex = 0; columnIndex < table.Columns.Count; columnIndex++)
            {
                worksheet.Rows[0].Cells[columnIndex].Value = table.Columns[columnIndex].ColumnName;
                worksheet.Rows[0].CellFormat.FormatString = "@";

                //*Added on 08-Oct-2013
                if (table.Columns[columnIndex].ColumnName == ddlSourceCol1.SelectedItem.Text)
                {
                    worksheet.Rows[0].Cells[columnIndex].Value = ddlTemplateCol1.SelectedItem.Text;

                    ///*V3.8-Added on 22 Oct2013-By Amar Vidya
                    if (ddlTemplateCol1.SelectedItem.Text == "StartPosition")
                    {
                        for (int S = 0; S < table.Rows.Count; S++)
                        {
                           
                            string StartPositionvalue = Convert.ToString(table.Rows[S][ddlSourceCol1.SelectedItem.Text]);
                            
                            Regex reg = new Regex(@"[^0-9]");
                          
                            string strStartPosition = reg.Replace(StartPositionvalue, "");
                         
                            //Start Position
                            if (!string.IsNullOrEmpty(strStartPosition))
                            {
                                if (Convert.ToInt64(strStartPosition) > 60)
                                {
                                    table.Rows[S][ddlSourceCol1.SelectedItem.Text] = null;
                                }
                                else
                                {
                                    table.Rows[S][ddlSourceCol1.SelectedItem.Text] = strStartPosition;
                                }
                            }
                            else
                            {
                                table.Rows[S][ddlSourceCol1.SelectedItem.Text] = null;
                            }
                         
                        }
                    }
                    else if (ddlTemplateCol1.SelectedItem.Text == "NoofRus")
                    {
                        for (int N = 0; N < table.Rows.Count; N++)
                        {

                            string NoofRusvalue = Convert.ToString(table.Rows[N][ddlSourceCol1.SelectedItem.Text]);
