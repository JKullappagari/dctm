    private void ddlTemplateCheck()
    {
        //if (ddlTemplateCol1.SelectedItem.Text == "Equipmenttype" && ddlTemplateCol2.SelectedItem.Text == "Manufacture" && ddlTemplateCol3.SelectedItem.Text == "Model" && ddlTemplateCol4.SelectedItem.Text == "Site" && ddlTemplateCol5.SelectedItem.Text == "Room")
        //||((ddlTemplateCol1.SelectedItem.Text == "Equipmenttype" && ddlTemplateCol2.SelectedItem.Text == "Manufacture" && ddlTemplateCol3.SelectedItem.Text == "Model" && ddlTemplateCol4.SelectedItem.Text == "Site" && ddlTemplateCol5.SelectedItem.Text == "Room"))

        //{
        //}
        if (Session["listMandatoryColNames"] != null)
        {
            listMandatoryColNames = (List<string>)Session["listMandatoryColNames"];
        }
        if (Session["listTempSelColNames"] != null)
        {
            listTempSelColNames = (List<string>)Session["listTempSelColNames"];
        }
        //string Mandatory = "Equipmenttype,Manufacture,Model,Site,Room";

        int i = 0;
        foreach (string lTempSelColNames in listTempSelColNames)
        {

            if (lTempSelColNames == "Equipmenttype")
            {
                i = i + 1;
            }
            else if (lTempSelColNames == "Manufacturer")
            {
                i = i + 1;
            }
            else if (lTempSelColNames == "Model")
            {
                i = i + 1;
            }
            else if (lTempSelColNames == "Site")
            {
                i = i + 1;
            }
            else if (lTempSelColNames == "Room")
            {
                i = i + 1;
            }

        }
        if (i >= 5)
        {
            btnImportAssetSheet.Enabled = true;
            lblMandatory.Text = "";
        }
        else
        {
            btnImportAssetSheet.Enabled = false;
            lblMandatory.Text = "* Equipmenttype,Manufacturer,Model,Site,Room needs to be selected for convertion";

        }
    }

