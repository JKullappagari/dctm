                            Regex reg = new Regex(@"[^0-9]");
                            //===== Read Label value and replace all non numeric characters with '' 

                            string strNoofRus = reg.Replace(NoofRusvalue, "");

                            //NoOfRUs
                            if (!string.IsNullOrEmpty(strNoofRus))
                            {
                                if (Convert.ToInt64(strNoofRus) > 60)
                                {
                                    table.Rows[N][ddlSourceCol11.SelectedItem.Text] = null;
                                }
                                else
                                {
                                    table.Rows[N][ddlSourceCol11.SelectedItem.Text] = strNoofRus;
                                }
                            }
                            else
                            {
                                table.Rows[N][ddlSourceCol11.SelectedItem.Text] = null;
                            }

                        }

                    }


                    //*

                }
                if (table.Columns[columnIndex].ColumnName == ddlSourceCol12.SelectedItem.Text)
                {
                    worksheet.Rows[0].Cells[columnIndex].Value = ddlTemplateCol12.SelectedItem.Text;

                    ///*V3.8-Added on 22 Oct2013-By Amar Vidya
                    if (ddlTemplateCol12.SelectedItem.Text == "StartPosition")
                    {
                        for (int S = 0; S < table.Rows.Count; S++)
                        {
                           
                            string StartPositionvalue = Convert.ToString(table.Rows[S][ddlSourceCol12.SelectedItem.Text]);

                            Regex reg = new Regex(@"[^0-9]");

                            string strStartPosition = reg.Replace(StartPositionvalue, "");

                            //Start Position
                            if (!string.IsNullOrEmpty(strStartPosition))
                            {
                                if (Convert.ToInt64(strStartPosition) > 60)
                                {
                                    table.Rows[S][ddlSourceCol12.SelectedItem.Text] = null;
                                }
                                else
                                {
                                    table.Rows[S][ddlSourceCol12.SelectedItem.Text] = strStartPosition;
                                }
                            }
                            else
                            {
                                table.Rows[S][ddlSourceCol12.SelectedItem.Text] = null;
                            }

                        }
                    }
                    else if (ddlTemplateCol12.SelectedItem.Text == "NoofRus")
                    {
                        for (int N = 0; N < table.Rows.Count; N++)
                        {

                            string NoofRusvalue = Convert.ToString(table.Rows[N][ddlSourceCol12.SelectedItem.Text]);
                            //==== Create Regex object and pass pattern. 
                            Regex reg = new Regex(@"[^0-9]");
                            //===== Read Label value and replace all non numeric characters with '' 

                            string strNoofRus = reg.Replace(NoofRusvalue, "");

                            //NoOfRUs
                            if (!string.IsNullOrEmpty(strNoofRus))
                            {
                                if (Convert.ToInt64(strNoofRus) > 60)
                                {
                                    table.Rows[N][ddlSourceCol12.SelectedItem.Text] = null;
                                }
                                else
                                {
                                    table.Rows[N][ddlSourceCol12.SelectedItem.Text] = strNoofRus;
                                }
                            }
                            else
                            {
                                table.Rows[N][ddlSourceCol12.SelectedItem.Text] = null;
                            }

                        }

                    }


                    //*

                }

              
            }
            

          
            for (int columnIndex = 0; columnIndex < table.Columns.Count; columnIndex++)
            {
                listUpdatedExcelColNamesAll.Add(worksheet.Rows[0].Cells[columnIndex].Value.ToString());
            }
            if (Session["listTempColNames"] != null)
            {
                listTempColNames = (List<string>)Session["listTempColNames"];
            }
            listTempColNames.RemoveAt(0);
            foreach (string s in listTempColNames.Except(listUpdatedExcelColNamesAll))
            {
               
                listTempExcludedFromUpdatedExcelColNamesAll.Add(s);
            }
           
            int i = table.Columns.Count;
                foreach (string item in listTempExcludedFromUpdatedExcelColNamesAll)
                {
                   
                      
                    worksheet.Rows[0].Cells[i].Value = item;
                    i = i + 1;
                }
                //V3.8-Added on 16Oct2013-By Amar Vidya
                worksheet.Rows[0].Cells[i].Value = "RackTag";
                worksheet.Rows[0].Cells[i+1].Value = "Orientation";//*
            listTempColNames.Insert(0, "--Select--");
            //*
            int rowIndex = 1;

            foreach (DataRow dataRow in table.Rows)
            {
                Infragistics.Documents.Excel.WorksheetRow row = worksheet.Rows[rowIndex++];

                for (int columnIndex = 0; columnIndex < dataRow.ItemArray.Length; columnIndex++)
                {
                    row.Cells[columnIndex].Value = dataRow.ItemArray[columnIndex];
                    row.Cells[columnIndex].CellFormat.FormatString = "@";

                }
            }



        }

      

        string filename = "ConvertedExcel.xls";
        //workbook.Save("C:\\Data.xls");
        //workbook.Save(Session["SavePath"].ToString());
        workbook.Save(Server.MapPath("~/AssetData/Data.xls"));
        //string Path = "C:\\Data.xls";
        string Path = Server.MapPath("~/AssetData/Data.xls");

        FileInfo OutFile = new FileInfo(Path);
        Response.Clear();

        Response.ContentType = "application/vnd.ms-excel";
        Response.AddHeader("Content-Disposition", "inline; filename=\"" + filename + "\"");

        Response.TransmitFile(Path, 0, OutFile.Length);
        Response.Flush();
        Response.End();



    }
