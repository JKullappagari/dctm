    protected void ibUpload_Click(object sender, Infragistics.WebUI.WebDataInput.ButtonEventArgs e)
    {
        if (ajaxFUExcel.HasFile)
        {
            string fileName = ajaxFUExcel.FileName;
            string savePath = MapPath("~/AssetData/" + Path.GetFileName(fileName));
            ajaxFUExcel.SaveAs(savePath);
            Session["SavePath"] = null;
            Session["SavePath"] = savePath;
            filepath = Session["SavePath"].ToString();
            RetrieveExcelSheetNames(Session["SavePath"].ToString());
            if (_dtRights.Select("Module = 'Import Excel Converter' and Rights = '" + "View" + "'").Length != 0)//Added on 15Apr2013
            {

                ddlSheetName.Enabled = false;

            }
            //else
            //{
            //    ddlSheetName.Enabled = true;
            //}
            if (_dtRights.Select("Module = 'Import Excel Converter' and Rights = '" + "Create" + "'").Length != 0)//Added on 15Apr2013
            {

                ddlSheetName.Enabled = true;

            }

            ///((AsyncFileUpload)sender).SaveAs(savePath);
        }
        ddlClear();
        SessionClear();//Added on 8Apr2013

    }
