    protected void ddlSourceCol2_SelectedIndexChanged(object sender, EventArgs e)
    {
        ddlSheetName.Enabled = true;
        if (ddlSourceCol2.SelectedIndex > 0)
        {
            ddlTemplateCol2.Enabled = true;
        }
        else
        {
            ddlTemplateCol2.Enabled = false;
            ddlTemplateCol2.SelectedIndex = 0;
        }
        ddlValidate();
        ///////////////////////////////////////////

        SourceItemNames();
        if (Session["listColNames1"] != null)
        {
            listColNames1 = (List<string>)Session["listColNames1"];
        }
        if (Session["listSelColNames1"] != null)
        {
            listSelColNames1 = (List<string>)Session["listSelColNames1"];
        }
        ddlSourceCol1.Items.Clear();
        ddlSourceCol3.Items.Clear();
        ddlSourceCol4.Items.Clear();
        ddlSourceCol5.Items.Clear();
        ddlSourceCol6.Items.Clear();
        ddlSourceCol7.Items.Clear();
        ddlSourceCol8.Items.Clear();
        ddlSourceCol9.Items.Clear();
        ddlSourceCol10.Items.Clear();
        ddlSourceCol11.Items.Clear();
        ddlSourceCol12.Items.Clear();
        //*Added on 07May2013
        ddlSourceCol13.Items.Clear();
        ddlSourceCol14.Items.Clear();//*


        foreach (string s in listColNames1.Except(listSelColNames1))
        {

            ddlSourceCol1.Items.Add(new ListItem(s.Trim()));
            ddlSourceCol3.Items.Add(new ListItem(s.Trim()));
