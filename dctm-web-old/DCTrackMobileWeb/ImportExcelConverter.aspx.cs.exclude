    private void ddlValidate()
    {
        lblMessage.Visible = true;
        if ((ddlSourceCol1.SelectedIndex > 0) && (ddlTemplateCol1.SelectedIndex == 0))
        {
            lblMessage.Text = "* Template Column required for corresponding source column selection";
            btnImportAssetSheet.Enabled = false;
        }

        else if ((ddlSourceCol2.SelectedIndex > 0) && (ddlTemplateCol2.SelectedIndex == 0))
