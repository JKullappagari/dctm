    private void RetrieveExcelSheetNames(string filePath)
    {
        OleDbConnection objConn = null;
        System.Data.DataTable dt = null;

        try
        {

            String connString = "Provider=Microsoft.ACE.OLEDB.12.0;Data Source=" + filepath + ";Extended Properties=\"Excel 12.0 Xml;IMEX=1;HDR=YES;\" ";
            // Create connection object by using the preceding connection string.
            objConn = new OleDbConnection(connString);
            // Open connection with the database.
            objConn.Open();
            // Get the data table containg the schema guid.
            dt = objConn.GetOleDbSchemaTable(OleDbSchemaGuid.Tables, null);

            if (dt == null)
            {
                // return null;
            }

            String[] excelSheets = new String[dt.Rows.Count];
            int i = 0;
            ddlSheetName.Items.Clear();
            ddlSheetName.Items.Add("--Select--");
            // Add the sheet name 
            foreach (DataRow row in dt.Rows)
            {
                excelSheets[i] = row["TABLE_NAME"].ToString();
                //if (excelSheets[i].Contains("_xlnm#_"))//Added on 8Apr02013//Commented on 9Apr2013
                //{
                //}
                //else if (excelSheets[i].Contains("owssvr_"))//Added on 8Apr02013//Commented on 9Apr2013
                //{ 
                //}
                if (excelSheets[i].EndsWith("$"))//Added on 9Apr2013
                {
                    ddlSheetName.Items.Add(new ListItem(excelSheets[i].ToString().Substring(0, excelSheets[i].Length - 1), excelSheets[i].ToString()));
                }
                //else if ((excelSheets[i].StartsWith("'")) && (excelSheets[i].EndsWith("'")))//Added on 9Apr2013
                else if (excelSheets[i].EndsWith("$'"))//Added on 9Apr2013
                {
                    string EliminateQ = excelSheets[i].ToString().Replace("'", string.Empty).ToString().Trim();

                    ddlSheetName.Items.Add(new ListItem(EliminateQ.Substring(0, EliminateQ.Length - 1), excelSheets[i].ToString()));
                }
                //else
                //{
                //    //if (excelSheets[i].Contains("'"))//Added on 8Apr02013
                //    //{
                //    //    string EliminateQ = excelSheets[i].ToString().Replace("'", string.Empty).ToString().Trim();
                //    //    //ddlSheetName.Items.Add(new ListItem(EliminateQ.Substring(0, EliminateQ.Length - 1)));//Added on 8Apr2013
                //    //    //ddlSheetName.Items.Add(new ListItem(EliminateQ.Substring(0, EliminateQ.Length - 1),excelSheets[i].ToString().Substring(0, excelSheets[i].Length - 1)));//Added on 8Apr2013
                //    //    ddlSheetName.Items.Add(new ListItem(EliminateQ.Substring(0, EliminateQ.Length - 1), excelSheets[i].ToString()));//Added on 8Apr2013
                //    //}
                //    //else
                //    //// excelSheets[i].ToString().Replace("'", string.Empty);
                //    ////ddlSheetName.Items.Add(new ListItem(excelSheets[i].ToString()));//Commented on 8Apr2013
                //    ////ddlSheetName.Items.Add(new ListItem(excelSheets[i].ToString().Replace("'", "").Substring(0, excelSheets[i].Length - 1)));//Added on 8Apr2013
                //    //{
                //        //ddlSheetName.Items.Add(new ListItem(excelSheets[i].ToString().Substring(0, excelSheets[i].Length - 1),excelSheets[i].ToString().Substring(0, excelSheets[i].Length - 1)));//Added on 8Apr2013
                //        ddlSheetName.Items.Add(new ListItem(excelSheets[i].ToString().Substring(0, excelSheets[i].Length - 1), excelSheets[i].ToString()));//Added on 8Apr2013
                //    //}
                //}
                i++;

            }


        }
        catch (Exception ex)
        {
            // return null;
        }
        finally
        {
            // Clean up.
            if (objConn != null)
            {
                objConn.Close();
                objConn.Dispose();
            }
            if (dt != null)
            {
                dt.Dispose();
            }
        }

    }
