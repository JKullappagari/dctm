    public DataSet ImportExcel(string FileName, string SheetName)
    {
        string strConn = "Provider=Microsoft.ACE.OLEDB.12.0;Data Source=" + FileName + ";Extended Properties=\"Excel 12.0 Xml;IMEX=1;HDR=YES;\" ";
        DataSet output = new DataSet();
        DataSet output1 = new DataSet();

        using (OleDbConnection conn = new OleDbConnection(strConn))
        {

            //foreach (DataTable table in ds.Tables)
            //{

            //    // Create the worksheet to represent this data table
            //    Infragistics.Documents.Excel.Worksheet worksheet = workbook.Worksheets.Add(table.TableName);

            conn.Open();

            DataTable dt = conn.GetOleDbSchemaTable(OleDbSchemaGuid.Tables, new object[] { null, null, null, "TABLE" });
            DataTable dtTable = conn.GetOleDbSchemaTable(OleDbSchemaGuid.Tables, new object[] { null, null, null, "TABLE" });//Added on 9Apr2013


            // string sheet = ddlSheetName.SelectedItem.Text.ToString();//Commented on 8Apr02013
            string sheet = SheetName;//Added on 8Apr02013
            string ColName = null;
            foreach (DataRow row in dtTable.Rows)
            {
                string sheetN = row["TABLE_NAME"].ToString();
                if (sheetN.Equals(sheet, StringComparison.InvariantCultureIgnoreCase))
                {


                    OleDbCommand cmd1 = new OleDbCommand("SELECT * FROM [" + sheet + "] ", conn);
                    cmd1.CommandType = CommandType.Text;
                    DataTable outputTable1 = new DataTable(sheet);
                    output1.Tables.Add(outputTable1);
                    new OleDbDataAdapter(cmd1).Fill(outputTable1);
                    for (int i = 0; i < outputTable1.Columns.Count; i++)
                    {
                        //ColName = ColName + "[" + outputTable1.Columns[i].ColumnName + "]" + " <> null and ";
                        ColName = ColName + "[" + outputTable1.Columns[i].ColumnName + "]" + " is not null and ";
                        //ColName = ColName + outputTable1.Columns[i].ColumnName + "<>null and ";
                    }
                    //ColName = ColName + "'" + ((string)row["COLUMN_NAME"]) + "'" + "<>null and ";
                    ////delete blank rows
                    //output.Tables[0].BeginLoadData();
                    //(from cr in output.Tables[0].AsEnumerable()
                    // where cr.Field<string>("HostName") == null && cr.Field<string>("SerialNumber") == null &&
                    // cr.Field<string>("Site") == null && cr.Field<string>("Manufacture") == null &&
                    // cr.Field<string>("Model") == null && cr.Field<string>("Equipmenttype") == null &&
                    // cr.Field<string>("Room") == null && cr.Field<string>("RowID") == null &&
                    // cr.Field<string>("RackID") == null && cr.Field<string>("StartPosition") == null &&
                    // cr.Field<string>("NoofRus") == null && cr.Field<string>("Rack/Stand") == null
                    // select cr).ToList().ForEach(cr => cr.Delete());
                    //output.Tables[0].EndLoadData();
                    //output.Tables[0].AcceptChanges();

                }
            }



            //DataTable schemaTable = conn.GetSchema("Columns");


            //string ColName = null;
            //foreach (DataRow row in schemaTable.Rows)
            //{

            //    string tablename = row["TABLE_NAME"].ToString();


            //    if (tablename.Equals(sheet, StringComparison.InvariantCultureIgnoreCase))
            //    {

            //        ColName = ColName +"'"+ ((string)row["COLUMN_NAME"]) +"'"+ "<>null and ";

            //     }

            //}
            string Cols = ColName.Substring(0, ColName.Length - 5);

            //OleDbCommand cmd = new OleDbCommand("SELECT * FROM [" + sheet + "] where " + Cols, conn);
            OleDbCommand cmd = new OleDbCommand("SELECT * FROM [" + sheet + "]", conn);



            cmd.CommandType = CommandType.Text;
            DataTable outputTable = new DataTable(sheet);
            // outputTable = outputTable.Rows.Cast<DataRow>().Where(row => !row.ItemArray.All(field => field is System.DBNull || string.Compare((field as string).Trim(), string.Empty) == 0)).CopyToDataTable();
            output.Tables.Add(outputTable);
            new OleDbDataAdapter(cmd).Fill(outputTable);
            // outputTable = outputTable.Rows.Cast<DataRow>().Where(row => !row.ItemArray.All(field => field is System.DBNull || string.Compare((field as string).Trim(), string.Empty) == 0)).CopyToDataTable();
            if (outputTable != null)//Added on 23Apr2013---No data rows
            {
                if (outputTable.Rows.Count > 0)//Added on 23Apr2013---No data rows
                {

                    outputTable = outputTable.Rows.Cast<DataRow>().Where(row => row.ItemArray.Any(field => !(field is System.DBNull))).CopyToDataTable(); //Added on 15Apr2013
                    output.Tables.Clear();
                    output.Tables.Add(outputTable);
                    output.Tables[0].AcceptChanges();
                }
            }
            //delete blank rows
            //   output.Tables[0].BeginLoadData();
            //(from cr in output.Tables[0].AsEnumerable()
            // where cr.Field<string>("HostName") == null && cr.Field<string>("SerialNumber") == null &&
            // cr.Field<string>("Site") == null && cr.Field<string>("Manufacture") == null &&
            // cr.Field<string>("Model") == null && cr.Field<string>("Equipmenttype") == null &&
            // cr.Field<string>("Room") == null && cr.Field<string>("RowID") == null &&
            // cr.Field<string>("RackID") == null && cr.Field<string>("StartPosition") == null &&
            // cr.Field<string>("NoofRus") == null && cr.Field<string>("Rack/Stand") == null
            // select cr).ToList().ForEach(cr => cr.Delete());
            // output.Tables[0].EndLoadData();
            // output.Tables[0].AcceptChanges();

        }
        return output;
        // return outputTable;
    }


