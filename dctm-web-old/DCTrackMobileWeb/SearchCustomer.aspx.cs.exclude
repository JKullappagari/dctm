    protected void ddlCountry_SelectedIndexChanged(object sender, EventArgs e)
    {
        PopulateStateByCountryID(Convert.ToInt16(ddlCountry.SelectedValue));
        PopulateCityByCountryID(Convert.ToInt16(ddlCountry.SelectedValue));
        ///string tt=   ddlCountry.SelectedValue.ToString();

    }
    private void PopulateStateByCountryID(int CountryID)
    {
        objCountryStateCity = new iAssetTrack.BAL.CountryStateCityBAL();

        objCountryStateCity.CountryID = CountryID;
        DataSet dsState = objCountryStateCity.retrieveStateByCountyID();
        DataTable dtState = dsState.Tables[0];

        objCommon = new CommonBAL();
        objCommon.setDataSource(ddlState, dtState, "(All)");
    }
    private void PopulateCityByCountryID(int CountryID)
    {
        
        objCountryStateCity = new iAssetTrack.BAL.CountryStateCityBAL();
        objCountryStateCity.CountryID = CountryID;
        DataSet dsCity = objCountryStateCity.retrieveCityByCountyID();
        DataTable dtCity = dsCity.Tables[0];

        objCommon = new CommonBAL();
        objCommon.setDataSource(ddlCity, dtCity, "(All)");
    }
}
