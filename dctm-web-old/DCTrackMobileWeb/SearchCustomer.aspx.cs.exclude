    private iAssetTrack_WebDataGrid_Paging_CustomerPagerControl pagerControl;

    // J00007 by kjb on 26 Sep 2012
    # region new control declaration
    protected Label lblMessage;
    protected WebImageButton ibSearch;
    protected DropDownList ddlIndustryType, ddlAddressType, ddlCity, ddlCountry,ddlState;
    protected TextBox txtName,txtShortName;
