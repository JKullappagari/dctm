    protected void wdgCustomer_DataFiltered(object sender, Infragistics.Web.UI.GridControls.FilteredEventArgs e)
    {
        // Cast the WebDataGrid DataSource to a DataTable  
        DataTable dt = this.wdgCustomer.DataSource as DataTable;

        // Disable WebDataGrid Paging
        wdgCustomer.Behaviors.Paging.Enabled = false;

        hdnFilterCount.Value = wdgCustomer.Rows.Count.ToString();


        // Enable WebDataGrid Paging
       wdgCustomer.Behaviors.Paging.Enabled = true;
    }
    private void populateGrid()
    {
        objCustomer = new iAssetTrack.BAL.CustomerBAL();
        //objCustomer.BusinessUnitID = Convert.ToInt16(ddlBusinessUnit.SelectedValue);
        //objCustomer.CityID = Convert.ToInt16(ddlCity.SelectedValue);
        //objCustomer.IndustryID = Convert.ToInt16(ddlIndustryType.SelectedValue);

        if (ddlCity.SelectedIndex != -1)
        {
            objCustomer.CityID = Convert.ToInt16(ddlCity.SelectedValue);
        }
        else
        {
            objCustomer.CityID = 0;
        }
        if (ddlIndustryType.SelectedIndex != -1)
        {
            objCustomer.IndustryID = Convert.ToInt16(ddlIndustryType.SelectedValue);
        }
        else
        {
            objCustomer.IndustryID = 0;
        }

        objCustomer.Name = txtName.Text;
        objCustomer.ShortName = txtShortName.Text;
        objCustomer.AddressID = Convert.ToInt16(ddlAddressType.SelectedValue);

        DataSet dsSearchCustomer = null;

        dsSearchCustomer = objCustomer.CustomerDetailsSearch();

        DataTable dtGrid = objCustomer.CustomerDetailsSearch().Tables[0];
        totalRecordCount = dtGrid.Rows.Count;

        if (dsSearchCustomer.Tables[0].Rows.Count > 0)
        {
            
            this.wdgCustomer.DataSource = dsSearchCustomer.Tables[0].DefaultView;

            this.wdgCustomer.DataBind();
            
