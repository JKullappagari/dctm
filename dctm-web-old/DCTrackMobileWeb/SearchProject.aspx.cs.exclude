        ////objSearchProject.EndDate = Convert.ToDateTime(wdcEndDate.Value);


        //DataSet dsSearchProject = null;

        //dsSearchProject = objSearchProject.ProjectDetailsSearch();

        //if (dsSearchProject.Tables[0].Rows.Count > 0)
        //{
        //    this.wdgProject.DataSource = dsSearchProject.Tables[0].DefaultView;
        //    this.wdgProject.DataBind();
        //}

        populateGrid();
