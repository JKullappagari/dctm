    protected void wdgProject_InitializeRow(object sender, Infragistics.Web.UI.GridControls.RowEventArgs e)
    {

    }

    protected void ibReset_Click(object sender, Infragistics.WebUI.WebDataInput.ButtonEventArgs e)
    {
        clearFields();
        Session["ProjectID"] = null;
        populateGrid();///V000011 Added on 10-Oct-2012
    }
    private void clearFields()
    {
        txtCustomerCode.Text = "";
       // txtCustomerName.Text = "";
        txtProjectCode.Text = "";
        //this.wdcStartDate.Value = DateTime.Today;
        //this.wdcEndDate.Value = DateTime.Today;
        //wdcStartDate.NullDateLabel = "-- Select --";
        //wdcEndDate.NullDateLabel = "-- Select --";
